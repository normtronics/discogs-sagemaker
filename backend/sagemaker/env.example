# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# SageMaker Configuration
SAGEMAKER_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/SageMakerExecutionRole
BUCKET_NAME=your-sagemaker-bucket

# Optional: DigitalOcean Spaces (for image storage)
SPACES_REGION=nyc3
SPACES_BUCKET=your-spaces-bucket
SPACES_KEY=your-spaces-key
SPACES_SECRET=your-spaces-secret

