{
  "training": {
    "instance_type": "ml.p3.2xlarge",
    "instance_count": 1,
    "volume_size": 50,
    "max_runtime": 86400,
    "hyperparameters": {
      "epochs": 10,
      "batch_size": 16,
      "learning_rate": 0.001,
      "lr_step_size": 5,
      "lr_gamma": 0.1,
      "test_size": 0.2
    }
  },
  "deployment": {
    "instance_type": "ml.m5.large",
    "initial_instance_count": 1,
    "endpoint_name": "album-classifier",
    "data_capture": {
      "enabled": true,
      "sampling_percentage": 100
    },
    "auto_scaling": {
      "enabled": false,
      "min_capacity": 1,
      "max_capacity": 3,
      "target_value": 70.0
    }
  },
  "model": {
    "framework": "pytorch",
    "framework_version": "2.5.1",
    "python_version": "py311"
  }
}

